generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── PLAYER ────────────────────────────────────────────────────────────────────
model Player {
  id            String   @id @default(cuid())
  privyId       String   @unique          // Privy auth ID
  username      String   @unique
  walletAddress String?  @unique          // EVM wallet (auto-created via Privy)
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  // Economy
  gold          Int      @default(5)      // Starting gold
  seeds         Int      @default(5)
  lumiBalance   Float    @default(0)      // $LUMI accumulated, not yet withdrawn
  lumiTotal     Float    @default(0)      // Lifetime $LUMI earned

  // Inventory (stored as JSON for flexibility)
  inventory     Json     @default("{\"wheat\":0,\"carrot\":0,\"corn\":0,\"bread\":0,\"stew\":0,\"wrap\":0,\"ale\":0}")

  // Relations
  plots         Plot[]
  skills        PlayerSkill[]
  questProgress QuestProgress[]
  trades        Trade[]
  chatMessages  ChatMessage[]

  @@map("players")
}

// ── PLOTS ─────────────────────────────────────────────────────────────────────
model Plot {
  id          String      @id @default(cuid())
  playerId    String
  player      Player      @relation(fields: [playerId], references: [id])

  col         Int                          // Grid position
  row         Int
  fertility   Float       @default(0.1)   // 0.0 – 1.0
  isLocked    Boolean     @default(false)
  isWatered   Boolean     @default(false)

  // Crop state
  state       PlotState   @default(EMPTY)
  cropType    CropType?
  plantedAt   DateTime?                   // When seed went in
  readyAt     DateTime?                   // Pre-calculated harvest time

  updatedAt   DateTime    @updatedAt

  @@unique([playerId, col, row])
  @@map("plots")
}

enum PlotState {
  EMPTY
  TILLED
  PLANTED
  GROWING
  READY
  SCORCHED
  FROZEN
}

enum CropType {
  WHEAT
  CARROT
  CORN
  GOLDEN_WHEAT
}

// ── SKILLS ────────────────────────────────────────────────────────────────────
model PlayerSkill {
  id         String    @id @default(cuid())
  playerId   String
  player     Player    @relation(fields: [playerId], references: [id])
  skill      SkillType
  xp         Int       @default(0)
  level      Int       @default(1)

  @@unique([playerId, skill])
  @@map("player_skills")
}

enum SkillType {
  FARMING
  CRAFTING
  TRADING
  ALCHEMY
}

// ── QUESTS ────────────────────────────────────────────────────────────────────
model QuestProgress {
  id         String      @id @default(cuid())
  playerId   String
  player     Player      @relation(fields: [playerId], references: [id])
  questId    String                        // e.g. "s1", "d3", "a2"
  questType  QuestType
  progress   Float       @default(0)
  claimed    Boolean     @default(false)
  claimedAt  DateTime?
  resetAt    DateTime?                     // For daily quests

  @@unique([playerId, questId])
  @@map("quest_progress")
}

enum QuestType {
  DAILY
  STORY
  ACHIEVEMENT
}

// ── CRAFTING QUEUE ────────────────────────────────────────────────────────────
model CraftJob {
  id          String    @id @default(cuid())
  playerId    String
  recipe      String                       // "bread", "stew", "wrap", "ale"
  startedAt   DateTime  @default(now())
  completesAt DateTime                     // Server-calculated
  collected   Boolean   @default(false)

  @@map("craft_jobs")
}

// ── TRADE BOARD ───────────────────────────────────────────────────────────────
model Trade {
  id         String      @id @default(cuid())
  sellerId   String
  seller     Player      @relation(fields: [sellerId], references: [id])
  crop       String
  quantity   Int
  priceEach  Int
  filled     Boolean     @default(false)
  filledBy   String?
  createdAt  DateTime    @default(now())
  expiresAt  DateTime                      // Trades expire after 24h

  @@map("trades")
}

// ── MARKET PRICES ─────────────────────────────────────────────────────────────
model MarketPrice {
  id        String   @id @default(cuid())
  item      String   @unique
  price     Float
  updatedAt DateTime @updatedAt

  @@map("market_prices")
}

// ── CHAT ──────────────────────────────────────────────────────────────────────
model ChatMessage {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  region    String   @default("global")   // "global", "farm:{playerId}", "guild:{id}"
  content   String
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

// ── FEE PULSE LOG ─────────────────────────────────────────────────────────────
model FeePulse {
  id         String   @id @default(cuid())
  volume     Float                         // Simulated DEX volume
  multiplier Float
  lumiMinted Float                         // Total $LUMI emitted this pulse
  createdAt  DateTime @default(now())

  @@map("fee_pulses")
}

// ── NPC RELATIONSHIPS ─────────────────────────────────────────────────────────
model NPCRelationship {
  id          String   @id @default(cuid())
  playerId    String
  npcName     String                        // "Mira" | "Finn" | "Lyra"
  hearts      Int      @default(0)          // 0–10
  lastGiftAt  DateTime?
  totalGifts  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([playerId, npcName])
  @@map("npc_relationships")
}

model NPCRelationship {
  id          String   @id @default(cuid())
  playerId    String
  npcName     String
  hearts      Int      @default(0)
  lastGiftAt  DateTime?
  totalGifts  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([playerId, npcName])
  @@map("npc_relationships")
}
